{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eros.nft/spec/v1.0/persona-manifest.schema.json",
  "title": "PersonaManifest",
  "description": "Published artifact. Carries no plaintext prompt; references ciphertext via prompt_ciphertext_ref. Chain-agnostic: contains no asset_id / chain fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "persona_id",
    "minted_at",
    "name",
    "tagline",
    "description",
    "greeting",
    "avatar",
    "prompt_ciphertext_ref",
    "behavior",
    "compliance"
  ],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "spec_version": { "const": "1.0" },
    "persona_id": {
      "type": "string",
      "pattern": "^ern:1\\.0:[0-9A-HJKMNP-TV-Z]{26,27}$"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    },
    "name":        { "type": "string", "minLength": 1, "maxLength": 64 },
    "tagline":     { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "greeting":    { "type": "string", "minLength": 1, "maxLength": 1000 },
    "avatar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "sha256", "provenance"],
      "properties": {
        "uri": {
          "type": "string",
          "pattern": "^(https?:|ar:|ipfs:)"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "provenance": {
          "type": "string",
          "enum": ["self_created", "ai_generated", "licensed"]
        }
      }
    },
    "prompt_ciphertext_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kms_key_ref", "ciphertext_uri", "ciphertext_sha256", "alg", "aad"],
      "properties": {
        "kms_key_ref": {
          "type": "string",
          "pattern": "^kms://[^/]+/.+$"
        },
        "ciphertext_uri": {
          "type": "string",
          "minLength": 1
        },
        "ciphertext_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "alg": { "const": "AES-256-GCM" },
        "aad": {
          "type": "string",
          "pattern": "^ern:1\\.0:[0-9A-HJKMNP-TV-Z]{26,27}$"
        }
      }
    },
    "behavior":   { "$ref": "https://eros.nft/spec/v1.0/persona-draft.schema.json#/$defs/Behavior" },
    "compliance": { "$ref": "https://eros.nft/spec/v1.0/persona-draft.schema.json#/$defs/Compliance" }
  }
}
